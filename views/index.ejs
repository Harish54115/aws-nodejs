<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>S3 Cloud Gallery</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #0f172a;
            --card-bg: rgba(30, 41, 59, 0.7);
            --border-color: rgba(255, 255, 255, 0.08);
            --primary: #6366f1;
            --primary-hover: #4f46e5;
            --danger: #ef4444;
            --danger-hover: #dc2626;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-color);
            background-image: 
                radial-gradient(at 0% 0%, rgba(99, 102, 241, 0.15) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(239, 68, 68, 0.08) 0px, transparent 50%);
            background-attachment: fixed;
            color: var(--text-main);
            min-height: 100vh;
            padding: 2rem 1.5rem;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        header {
            text-align: center;
            margin-bottom: 3rem;
            animation: fadeInDown 0.6s ease-out;
        }

        header h1 {
            font-size: 2.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, #a5b4fc 0%, #6366f1 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0.5rem;
        }

        header p {
            color: var(--text-muted);
            font-size: 1.1rem;
        }

        .upload-section {
            background: var(--card-bg);
            backdrop-filter: blur(16px);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 2rem;
            max-width: 600px;
            margin: 0 auto 3rem auto;
            box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.3);
            animation: fadeInUp 0.6s ease-out;
        }

        .drop-zone {
            border: 2px dashed rgba(99, 102, 241, 0.4);
            border-radius: 12px;
            padding: 2.5rem 1.5rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            background: rgba(99, 102, 241, 0.02);
        }

        .drop-zone:hover, .drop-zone.dragover {
            border-color: var(--primary);
            background: rgba(99, 102, 241, 0.06);
            transform: scale(1.01);
        }

        .drop-zone-icon {
            font-size: 2.5rem;
            color: var(--primary);
            margin-bottom: 1rem;
            display: inline-block;
            animation: float 3s ease-in-out infinite;
        }

        .drop-zone-text {
            color: var(--text-main);
            font-weight: 500;
            margin-bottom: 0.5rem;
        }

        .drop-zone-subtext {
            color: var(--text-muted);
            font-size: 0.85rem;
        }

        #fileInput {
            display: none;
        }

        .upload-status {
            margin-top: 1rem;
            padding: 0.75rem;
            border-radius: 8px;
            font-size: 0.9rem;
            display: none;
            text-align: center;
        }

        .status-loading {
            background: rgba(99, 102, 241, 0.1);
            color: #a5b4fc;
            border: 1px solid rgba(99, 102, 241, 0.2);
        }

        .status-success {
            background: rgba(34, 197, 94, 0.1);
            color: #4ade80;
            border: 1px solid rgba(34, 197, 94, 0.2);
        }

        .status-error {
            background: rgba(239, 68, 68, 0.1);
            color: #fca5a5;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        .gallery-title {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 0.5rem;
            animation: fadeIn 0.8s ease-out;
        }

        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 1.5rem;
            animation: fadeIn 0.8s ease-out;
        }

        .image-card {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            overflow: hidden;
            position: relative;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 20px -5px rgba(0, 0, 0, 0.2);
        }

        .image-card:hover {
            transform: translateY(-5px);
            border-color: rgba(99, 102, 241, 0.3);
            box-shadow: 0 12px 30px -10px rgba(99, 102, 241, 0.2);
        }

        .image-wrapper {
            width: 100%;
            height: 200px;
            background: #1e293b;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .image-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .image-card:hover .image-wrapper img {
            transform: scale(1.08);
        }

        .card-info {
            padding: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(15, 23, 42, 0.4);
        }

        .card-name {
            font-size: 0.85rem;
            color: var(--text-muted);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 70%;
        }

        .delete-btn {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: var(--danger);
            padding: 0.4rem 0.8rem;
            border-radius: 6px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .delete-btn:hover {
            background: var(--danger);
            color: var(--text-main);
            border-color: var(--danger);
            box-shadow: 0 0 12px rgba(239, 68, 68, 0.4);
        }

        .empty-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 4rem 2rem;
            color: var(--text-muted);
            border: 1px dashed var(--border-color);
            border-radius: 12px;
            background: rgba(30, 41, 59, 0.3);
        }

        .empty-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>S3 Cloud Gallery</h1>
            <p>Upload, manage, and view your images securely in AWS S3</p>
        </header>

        <section class="upload-section">
            <div class="drop-zone" id="dropZone">
                <span class="drop-zone-icon">☁️</span>
                <p class="drop-zone-text">Drag & drop your image here or click to browse</p>
                <p class="drop-zone-subtext">Supports PNG, JPG, JPEG, GIF, WEBP</p>
                <input type="file" id="fileInput" accept="image/*">
            </div>
            <div class="upload-status" id="uploadStatus"></div>
        </section>

        <main>
            <h2 class="gallery-title">Gallery Items</h2>
            <div class="gallery-grid">
                <% if (images && images.length > 0) { %>
                    <% images.forEach(image => { %>
                        <% 
                            // Extract just the filename for cleaner UI
                            const displayKey = image.key.replace(/^images\//, '');
                        %>
                        <div class="image-card">
                            <div class="image-wrapper">
                                <img src="<%= image.url %>" alt="<%= displayKey %>" loading="lazy">
                            </div>
                            <div class="card-info">
                                <span class="card-name" title="<%= displayKey %>"><%= displayKey %></span>
                                <button class="delete-btn" onclick="deleteImage('<%= image.key %>')">Delete</button>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="empty-state">
                        <div class="empty-icon">🖼️</div>
                        <h3>No images uploaded yet</h3>
                        <p>Use the drop zone above to upload your first image to AWS S3.</p>
                    </div>
                <% } %>
            </div>
        </main>
    </div>

    <script>
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        const uploadStatus = document.getElementById('uploadStatus');

        // Setup dropzone click to browse files
        dropZone.addEventListener('click', () => fileInput.click());

        // File drag and drop events
        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('dragover');
        });

        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('dragover');
        });

        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('dragover');
            if (e.dataTransfer.files.length) {
                handleUpload(e.dataTransfer.files[0]);
            }
        });

        // File input selection
        fileInput.addEventListener('change', () => {
            if (fileInput.files.length) {
                handleUpload(fileInput.files[0]);
            }
        });

        // Show status helper
        function showStatus(text, type) {
            uploadStatus.textContent = text;
            uploadStatus.className = `upload-status status-${type}`;
            uploadStatus.style.display = 'block';
        }

        // Upload handler using AJAX/Fetch
        async function handleUpload(file) {
            const formData = new FormData();
            formData.append('image', file);

            showStatus('Uploading to S3...', 'loading');

            try {
                const response = await fetch('/api/images/upload', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (response.ok && result.success) {
                    showStatus('Image uploaded successfully! Reloading...', 'success');
                    setTimeout(() => {
                        window.location.reload();
                    }, 1000);
                } else {
                    showStatus(result.message || 'Failed to upload image.', 'error');
                }
            } catch (err) {
                showStatus('An error occurred during upload.', 'error');
                console.error(err);
            }
        }

        // Delete handler using AJAX/Fetch
        async function deleteImage(key) {
            if (confirm("Are you sure you want to delete this image from S3?")) {
                try {
                    const response = await fetch(`/api/images/${encodeURIComponent(key)}`, {
                        method: 'DELETE'
                    });

                    const result = await response.json();

                    if (response.ok && result.success) {
                        window.location.reload();
                    } else {
                        alert(result.message || 'Failed to delete image.');
                    }
                } catch (err) {
                    alert('An error occurred during deletion.');
                    console.error(err);
                }
            }
        }
    </script>
</body>
</html>
